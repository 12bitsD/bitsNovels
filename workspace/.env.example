BITSNOVELS_APP_ENV=development
BITSNOVELS_APP_NAME=bitsNovels API
BITSNOVELS_APP_VERSION=0.1.0

# Which LLM provider to use: moonshot | mimo
LLM_PROVIDER=mimo

# Kimi (Moonshot) API
# NOTE: Local dev only. Do NOT commit real keys.
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# MiMo OpenAI-compatible API
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
# If your deployment requires this endpoint, set MIMO_BASE_URL to:
# https://token-plan-cn.xiaomimimo.com/v1

# AI defaults (system baseline; project/user can override via API)
AI_DEFAULT_MODEL=mimo-v2-pro
AI_DEFAULT_TEMPERATURE=0.7
AI_DEFAULT_MAX_LENGTH=1200
AI_DEFAULT_PARSE_DEPTH=standard
